// Núcleo — modelo de datos del Core de RRHH
// Documentado en CLAUDE.md y PLAN.md. Dinero en euros (Int); si se requiere
// precisión contable, migrar campos monetarios a Decimal.

generator client {
  provider        = "prisma-client-js"
  // Auditoría de rendimiento: convierte los `include` con relaciones en un JOIN real (1 query)
  // en vez de una query por relación (batched vía "WHERE id IN (...)"). Bajo el pooler de
  // Supabase, cada query de más cuesta una tanda extra de BEGIN/DEALLOCATE ALL/COMMIT — este
  // cambio es el de mayor impacto agregado porque toca todos los `include` pesados a la vez.
  previewFeatures = ["relationJoins"]
}

// DATABASE_URL: pooler de Supabase (Supavisor, puerto 6543, ?pgbouncer=true) — usado en runtime.
// DIRECT_URL: conexión directa (puerto 5432) — usada solo por `prisma migrate`/`db:seed`/`db:studio`.
// En local con docker-compose, ambas pueden apuntar a la misma cadena (no hay pooler).
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────── Enums ────────────────────────────
enum Role {
  ADMIN
  RRHH
  MANAGER
  EMPLEADO
}

enum EmployeeStatus {
  ACTIVO
  ONBOARDING
  AUSENTE
  BAJA
}

enum ContractType {
  INDEFINIDO
  TEMPORAL
  PRACTICAS
  FREELANCE
}

// humanX: vínculo de la persona con el grupo (plantilla propia vs. proveedor externo)
enum Vinculo {
  PLANTILLA
  EXTERNO
}

// humanX: estado de una anotación de Memoria (nota + tarea ligera)
enum EstadoAnotacion {
  PENDIENTE
  HECHA
}

enum AbsenceType {
  VACACIONES
  ENFERMEDAD
  PERSONAL
  MATERNIDAD
}

enum AbsenceStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

// humanX: generaliza Onboarding a Proceso (Onboarding + Offboarding). "fase" pasa de enum
// fijo a texto libre por plantilla — con Offboarding, las fases dejan de ser "primer día,
// primera semana…"; cada plantilla define las suyas, ordenadas por `orden`.
enum TipoProceso {
  ONBOARDING
  OFFBOARDING
}

enum EstadoProceso {
  NO_INICIADO
  EN_CURSO
  COMPLETADO
  CANCELADO
}

enum EstadoTarea {
  PENDIENTE
  EN_CURSO
  COMPLETADA
  BLOQUEADA
  CANCELADA
}

enum CycleStatus {
  BORRADOR
  ACTIVO
  CERRADO
}

enum PayrollStatus {
  BORRADOR
  PROCESADA
  PAGADA
}

enum PayslipStatus {
  BORRADOR
  EMITIDA
  PAGADA
}

enum PayrollItemType {
  BONUS
  HORAS_EXTRA
  DEDUCCION
}

enum DocumentCategory {
  CONTRATOS
  NOMINAS
  POLITICAS
  CERTIFICADOS
  FORMACION
}

enum DocumentStatus {
  VIGENTE
  FIRMADO
  PENDIENTE
  EMITIDO
}

enum SignatureStatus {
  PENDIENTE
  FIRMADA
}

// Reclutamiento (VITAE)
enum JobStatus {
  BORRADOR
  ABIERTA
  PAUSADA
  CERRADA
}

enum ApplicationStatus {
  ACTIVO
  RECHAZADO
  CONTRATADO
  RETIRADO
}

enum CandidateSource {
  PORTAL
  REFERIDO
  LINKEDIN
  AGENCIA
  OTRO
}

// ─────────────────────── Identidad / Organización ───────────────────────
model User {
  id            String          @id @default(cuid())
  email         String          @unique
  passwordHash  String
  role          Role            @default(EMPLEADO)
  employee      Employee?       @relation(fields: [employeeId], references: [id])
  employeeId    String?         @unique
  lastLogin     DateTime?
  createdAt     DateTime        @default(now())
  notifications Notification[]
  auditLogs     AuditLog[]      @relation("AuditActor")
  decisions     AuditDecision[] @relation("DecisionActor")
  anotaciones   Anotacion[]     @relation("AnotacionAutor")
}

model Department {
  id              String           @id @default(cuid())
  name            String           @unique
  color           String
  lead            Employee?        @relation("DeptLead", fields: [leadId], references: [id])
  leadId          String?
  members         Employee[]       @relation("DeptMembers")
  jobs            Job[]
  registrosPuesto RegistroPuesto[]
}

// ──────────────────────── Estructura (humanX) ────────────────────────
model Pais {
  id         String     @id @default(cuid())
  nombre     String     @unique
  sociedades Sociedad[]
}

model Sociedad {
  id              String           @id @default(cuid())
  nombre          String           @unique
  pais            Pais             @relation(fields: [paisId], references: [id])
  paisId          String
  empleados       Employee[]
  registrosPuesto RegistroPuesto[]
}

model Localizacion {
  id        String     @id @default(cuid())
  nombre    String     @unique
  empleados Employee[]
}

model Employee {
  id              String         @id @default(cuid())
  fullName        String
  email           String         @unique
  phone           String?
  jobTitle        String
  level           String // exec | lead | senior | mid | junior
  location        String
  remote          Boolean        @default(false)
  startDate       DateTime
  contractType    ContractType   @default(INDEFINIDO)
  status          EmployeeStatus @default(ACTIVO)
  salary          Int? // bruto anual en euros
  birthday        String?
  dni             String?
  address         String?
  iban            String?
  emergency       String?
  fromRecruitment Boolean        @default(false)

  // humanX: expediente — código interno, vínculo, sociedad/localización y alertas de contrato
  codigo              String?
  vinculo             Vinculo       @default(PLANTILLA)
  sociedad            Sociedad?     @relation(fields: [sociedadId], references: [id])
  sociedadId          String?
  localizacion        Localizacion? @relation(fields: [localizacionId], references: [id])
  localizacionId      String?
  finPeriodoPrueba    DateTime?
  vencimientoContrato DateTime?
  descripcionPuesto   String?

  department   Department?  @relation("DeptMembers", fields: [departmentId], references: [id])
  departmentId String?
  leadingDepts Department[] @relation("DeptLead")

  manager   Employee?  @relation("Reports", fields: [managerId], references: [id])
  managerId String?
  reports   Employee[] @relation("Reports")

  user User?

  absences         Absence[]           @relation("EmployeeAbsences")
  approvedAbsences Absence[]           @relation("AbsenceApprover")
  balances         LeaveBalance[]
  procesos         Proceso[]           @relation("OnbEmployee")
  buddyOf          Proceso[]           @relation("OnbBuddy")
  reviews          Review[]            @relation("ReviewEmployee")
  reviewing        Review[]            @relation("ReviewReviewer")
  objectives       Objective[]
  payslips         Payslip[]
  payrollItems     PayrollItem[]
  documents        Document[]          @relation("DocOwner")
  signatures       DocumentSignature[]
  timeEntries      TimeEntry[]

  // humanX: memoria — anotaciones sobre esta persona
  anotaciones Anotacion[]

  // humanX: expediente — histórico de puesto y salarial
  registrosPuesto     RegistroPuesto[]
  registrosSalariales RegistroSalarial[]

  // Reclutamiento (VITAE): de dónde vino y en qué procesos participa
  candidate        Candidate?   @relation("CandidateHired", fields: [candidateId], references: [id])
  candidateId      String?      @unique
  hiringFor        Job[]        @relation("JobHiringManager")
  interviewsGiven  Interview[]
  evaluationsGiven Evaluation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([managerId])
  @@index([sociedadId])
  @@index([localizacionId])
  @@index([status])
  @@index([vinculo])
}

// ──────────────────────────── Expediente (humanX) ────────────────────────────
// El puesto/sociedad/departamento ACTUALES siguen viviendo en Employee (fuente de verdad
// para filtros y listas); estos históricos son de solo lectura hacia atrás en el tiempo.
model RegistroPuesto {
  id             String      @id @default(cuid())
  empleado       Employee    @relation(fields: [empleadoId], references: [id])
  empleadoId     String
  fechaInicio    DateTime
  fechaFin       DateTime? // null = puesto actual
  titulo         String
  sociedad       Sociedad?   @relation(fields: [sociedadId], references: [id])
  sociedadId     String?
  departamento   Department? @relation(fields: [departamentoId], references: [id])
  departamentoId String?
  createdAt      DateTime    @default(now())

  @@index([empleadoId])
}

// El Δ respecto al registro anterior se calcula en la vista, no se guarda.
model RegistroSalarial {
  id         String   @id @default(cuid())
  empleado   Employee @relation(fields: [empleadoId], references: [id])
  empleadoId String
  fecha      DateTime
  concepto   String
  brutoAnual Int
  createdAt  DateTime @default(now())

  @@index([empleadoId])
}

// ──────────────────────────── Memoria (humanX) ────────────────────────────
model Categoria {
  id          String      @id @default(cuid())
  nombre      String      @unique
  color       String
  orden       Int         @default(0)
  anotaciones Anotacion[]
}

model Anotacion {
  id          String          @id @default(cuid())
  empleado    Employee        @relation(fields: [empleadoId], references: [id])
  empleadoId  String
  categoria   Categoria?      @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  categoriaId String?
  fecha       DateTime        @default(now())
  texto       String
  autor       User            @relation("AnotacionAutor", fields: [autorId], references: [id])
  autorId     String
  estado      EstadoAnotacion @default(PENDIENTE)
  hechaAt     DateTime?
  createdAt   DateTime        @default(now())

  @@index([empleadoId])
  @@index([categoriaId])
  @@index([estado])
  @@index([fecha])
}

// ──────────────────────────── Tiempo ────────────────────────────
model Absence {
  id         String        @id @default(cuid())
  employee   Employee      @relation("EmployeeAbsences", fields: [employeeId], references: [id])
  employeeId String
  type       AbsenceType
  startDate  DateTime
  endDate    DateTime
  days       Int
  status     AbsenceStatus @default(PENDIENTE)
  reason     String?
  approver   Employee?     @relation("AbsenceApprover", fields: [approverId], references: [id])
  approverId String?
  decidedAt  DateTime?
  createdAt  DateTime      @default(now())

  @@index([employeeId])
  @@index([status])
  // calendar() filtra por solape de rango (startDate <= to AND endDate >= from).
  @@index([startDate, endDate])
}

model LeaveBalance {
  id         String   @id @default(cuid())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String
  year       Int
  total      Int
  used       Int      @default(0)
  pending    Int      @default(0)

  @@unique([employeeId, year])
}

model Holiday {
  id       String   @id @default(cuid())
  date     DateTime
  name     String
  location String? // null = festivo nacional
}

model TimeEntry {
  id         String    @id @default(cuid())
  employee   Employee  @relation(fields: [employeeId], references: [id])
  employeeId String
  clockIn    DateTime
  clockOut   DateTime?
  source     String? // id de dispositivo / app
}

// ──────────────────────────── Talento ────────────────────────────
// Plantilla maestra (Fase G): versionable — duplicar crea una copia editable, archivar
// (activa:false) la retira de "Iniciar" sin borrar los procesos que ya la usaron.
model PlantillaProceso {
  id       String                  @id @default(cuid())
  nombre   String
  tipo     TipoProceso             @default(ONBOARDING)
  activa   Boolean                 @default(true)
  tareas   PlantillaProcesoTarea[]
  procesos Proceso[]
}

model PlantillaProcesoTarea {
  id          String           @id @default(cuid())
  plantilla   PlantillaProceso @relation(fields: [plantillaId], references: [id])
  plantillaId String
  label       String
  fase        String // texto libre (ordenado por `orden`), ya no un enum fijo
  responsable String
  orden       Int              @default(0)
}

// El puesto actual = Employee; este es el proceso de incorporación o salida asociado.
// Al iniciar, se COPIAN las tareas de la plantilla activa (no se referencian) — así un
// cambio posterior en la plantilla no altera procesos ya en marcha.
model Proceso {
  id            String            @id @default(cuid())
  tipo          TipoProceso       @default(ONBOARDING)
  nombre        String?
  employee      Employee          @relation("OnbEmployee", fields: [employeeId], references: [id])
  employeeId    String
  buddy         Employee?         @relation("OnbBuddy", fields: [buddyId], references: [id])
  buddyId       String?
  plantilla     PlantillaProceso? @relation(fields: [plantillaId], references: [id])
  plantillaId   String?
  fechaInicio   DateTime
  fechaObjetivo DateTime?
  estado        EstadoProceso     @default(EN_CURSO)
  tareas        ProcesoTarea[]

  @@index([employeeId])
  @@index([buddyId])
  @@index([plantillaId])
  @@index([tipo])
}

model ProcesoTarea {
  id           String      @id @default(cuid())
  proceso      Proceso     @relation(fields: [procesoId], references: [id])
  procesoId    String
  label        String
  fase         String
  responsable  String
  estado       EstadoTarea @default(PENDIENTE)
  completadaAt DateTime?

  @@index([procesoId])
}

model PerformanceCycle {
  id         String      @id @default(cuid())
  name       String
  startDate  DateTime
  endDate    DateTime
  status     CycleStatus @default(ACTIVO)
  reviews    Review[]
  objectives Objective[]
}

model Review {
  id          String           @id @default(cuid())
  cycle       PerformanceCycle @relation(fields: [cycleId], references: [id])
  cycleId     String
  employee    Employee         @relation("ReviewEmployee", fields: [employeeId], references: [id])
  employeeId  String
  reviewer    Employee?        @relation("ReviewReviewer", fields: [reviewerId], references: [id])
  reviewerId  String?
  selfDone    Boolean          @default(false)
  managerDone Boolean          @default(false)
  o2oDone     Boolean          @default(false)
  rating      Float?

  @@unique([cycleId, employeeId])
}

model Objective {
  id         String            @id @default(cuid())
  cycle      PerformanceCycle? @relation(fields: [cycleId], references: [id])
  cycleId    String?
  scope      String // "Empresa" | nombre de área
  owner      Employee          @relation(fields: [ownerId], references: [id])
  ownerId    String
  title      String
  keyResults KeyResult[]
}

model KeyResult {
  id          String    @id @default(cuid())
  objective   Objective @relation(fields: [objectiveId], references: [id])
  objectiveId String
  title       String
  progress    Int       @default(0)
}

// ──────────────────────────── Empresa ────────────────────────────
model PayrollRun {
  id          String        @id @default(cuid())
  period      String        @unique // "2026-06"
  status      PayrollStatus @default(BORRADOR)
  totalGross  Int           @default(0)
  totalCost   Int           @default(0)
  processedAt DateTime?
  createdAt   DateTime      @default(now())
  payslips    Payslip[]
  items       PayrollItem[]
}

model Payslip {
  id         String        @id @default(cuid())
  run        PayrollRun    @relation(fields: [runId], references: [id])
  runId      String
  employee   Employee      @relation(fields: [employeeId], references: [id])
  employeeId String
  gross      Int
  irpf       Int
  ss         Int
  net        Int
  status     PayslipStatus @default(BORRADOR)
  pdfUrl     String?

  @@unique([runId, employeeId])
  // El índice único cubre runId solo (prefijo izquierdo); mine() (payroll.service.ts) filtra
  // por employeeId solo, sin runId — necesita su propio índice.
  @@index([employeeId])
}

model PayrollItem {
  id         String          @id @default(cuid())
  run        PayrollRun      @relation(fields: [runId], references: [id])
  runId      String
  employee   Employee        @relation(fields: [employeeId], references: [id])
  employeeId String
  type       PayrollItemType
  concept    String
  amount     Int // euros; negativo = deducción

  // Siempre se consultan juntos: findMany({ where: { runId, employeeId } }).
  @@index([runId, employeeId])
}

model Document {
  id         String              @id @default(cuid())
  name       String
  category   DocumentCategory
  owner      Employee            @relation("DocOwner", fields: [ownerId], references: [id])
  ownerId    String
  fileUrl    String?
  status     DocumentStatus      @default(VIGENTE)
  createdAt  DateTime            @default(now())
  signatures DocumentSignature[]

  @@index([ownerId])
  @@index([category])
  @@index([status])
}

model DocumentSignature {
  id         String          @id @default(cuid())
  document   Document        @relation(fields: [documentId], references: [id])
  documentId String
  employee   Employee        @relation(fields: [employeeId], references: [id])
  employeeId String
  status     SignatureStatus @default(PENDIENTE)
  signedAt   DateTime?

  @@unique([documentId, employeeId])
  // El índice único ya cubre búsquedas por documentId (prefijo izquierdo); "mis firmas"
  // (mine(), documents.service.ts) filtra por employeeId solo, sin documentId — necesita su
  // propio índice.
  @@index([employeeId])
}

model DocumentTemplate {
  id       String           @id @default(cuid())
  name     String
  category DocumentCategory
  fileUrl  String?
}

// ─────────────────────── Reclutamiento (VITAE) ───────────────────────
// Módulo interno: cuando una Application pasa a CONTRATADO, su Candidate se
// convierte en Employee (Employee.candidateId) y arranca su Proceso de tipo ONBOARDING.
model Job {
  id              String        @id @default(cuid())
  title           String
  department      Department?   @relation(fields: [departmentId], references: [id])
  departmentId    String?
  location        String
  remote          Boolean       @default(false)
  level           String
  contractType    ContractType  @default(INDEFINIDO)
  status          JobStatus     @default(ABIERTA)
  openings        Int           @default(1)
  description     String?
  hiringManager   Employee?     @relation("JobHiringManager", fields: [hiringManagerId], references: [id])
  hiringManagerId String?
  createdAt       DateTime      @default(now())
  closedAt        DateTime?
  applications    Application[]
}

model Candidate {
  id           String          @id @default(cuid())
  fullName     String
  email        String          @unique
  phone        String?
  source       CandidateSource @default(PORTAL)
  linkedinUrl  String?
  resumeUrl    String?
  createdAt    DateTime        @default(now())
  applications Application[]
  hiredAs      Employee?       @relation("CandidateHired")
}

model Stage {
  id           String        @id @default(cuid())
  name         String        @unique
  order        Int
  applications Application[]
}

model Application {
  id          String            @id @default(cuid())
  job         Job               @relation(fields: [jobId], references: [id])
  jobId       String
  candidate   Candidate         @relation(fields: [candidateId], references: [id])
  candidateId String
  stage       Stage?            @relation(fields: [stageId], references: [id])
  stageId     String?
  status      ApplicationStatus @default(ACTIVO)
  rating      Float?
  notes       String?
  appliedAt   DateTime          @default(now())
  interviews  Interview[]
  evaluations Evaluation[]
  decisions   AuditDecision[]

  @@unique([jobId, candidateId])
}

model Interview {
  id            String      @id @default(cuid())
  application   Application @relation(fields: [applicationId], references: [id])
  applicationId String
  interviewer   Employee?   @relation(fields: [interviewerId], references: [id])
  interviewerId String?
  scheduledAt   DateTime?
  type          String // telefonica | tecnica | cultural | final
  status        String      @default("PROGRAMADA")
  feedback      String?
}

model Evaluation {
  id             String      @id @default(cuid())
  application    Application @relation(fields: [applicationId], references: [id])
  applicationId  String
  evaluator      Employee?   @relation(fields: [evaluatorId], references: [id])
  evaluatorId    String?
  score          Float?
  strengths      String?
  concerns       String?
  recommendation String? // contratar | rechazar | dudoso
  createdAt      DateTime    @default(now())
}

// Traza de decisiones (incl. automáticas) — soporte para auditoría / EU AI Act
model AuditDecision {
  id            String      @id @default(cuid())
  application   Application @relation(fields: [applicationId], references: [id])
  applicationId String
  type          String // AUTO_SCREEN | ADVANCE_STAGE | REJECT | MAKE_OFFER | HIRE
  automated     Boolean     @default(false)
  reason        String?
  actor         User?       @relation("DecisionActor", fields: [actorId], references: [id])
  actorId       String?
  createdAt     DateTime    @default(now())
}

// ──────────────────────────── Transversal ────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id])
  actorId   String?
  action    String // CREATE | UPDATE | DELETE | APPROVE | REJECT | SIGN | PROCESS_PAYROLL ...
  entity    String // Employee | Absence | Payslip ...
  entityId  String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  // Sin consumidor todavía (no hay "Registro de accesos" en Informes aún), pero
  // PLAN-humanX.md §5.10 ya lo promete y esta tabla crece con cada apertura de ficha (VIEW) —
  // se adelanta el índice por el que se consultará (entidad+id, orden cronológico).
  @@index([entity, entityId])
  @@index([actorId])
}

model Notification {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  type      String
  payload   Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())
}
