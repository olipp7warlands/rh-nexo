# ── Base de datos ──
# En local (docker-compose): ambas pueden ser la misma cadena, no hay pooler.
# En Supabase: DATABASE_URL = cadena del "Connection pooling" (Transaction mode, puerto 6543,
# con ?pgbouncer=true&connection_limit=1) — la usa la API en runtime.
# DIRECT_URL = cadena de "Connection string" directa (puerto 5432) — la usan
# `prisma migrate deploy`/`db:seed`/`db:studio`. Ambas están en
# Supabase → Project Settings → Database.
DATABASE_URL="postgresql://nucleo:nucleo@localhost:5432/nucleo?schema=public"
DIRECT_URL="postgresql://nucleo:nucleo@localhost:5432/nucleo?schema=public"

# ── Auth ──
JWT_SECRET="cambia-esto-por-un-secreto-largo"
JWT_REFRESH_SECRET="cambia-esto-tambien"
JWT_EXPIRES_IN="15m"

# ── Servidor ──
PORT="3000"
# Orígenes permitidos por CORS, separados por comas (front local + producción + previews).
WEB_ORIGIN="http://localhost:5173"

# ── Almacenamiento ──
# "" (vacío) = LocalStorageProvider (no-op, igual que hoy). "supabase" = SupabaseStorageProvider
# real. Hoy NINGÚN módulo de negocio usa este proveedor todavía (ver apps/api/src/storage) —
# queda listo para cuando se implemente la subida de ficheros real.
STORAGE_PROVIDER=""
SUPABASE_URL="https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="cambia-esto-por-la-service-role-key-de-supabase"
SUPABASE_STORAGE_BUCKET="nucleo-docs"

# ── Firma electrónica (proveedor; vacío = modo mock en local) ──
SIGNATURE_PROVIDER=""
SIGNATURE_API_KEY=""

# ── Frontend (Vite, solo se usa en build time del front) ──
VITE_API_URL="http://localhost:3000"
