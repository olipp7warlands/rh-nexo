# ── Base de datos ──
# En local (docker-compose): ambas pueden ser la misma cadena, no hay pooler.
# En Supabase: DATABASE_URL = "Connection pooling" en modo Transaction, puerto 6543, con
# ?pgbouncer=true&connection_limit=1 — la usa la API en runtime.
# DIRECT_URL = la conexión directa clásica (db.<ref>.supabase.co:5432) es IPv6-only y falla
# (P1001) desde redes sin IPv6. Si te pasa, usa el MISMO host del pooler pero en modo Session
# (puerto 5432, sin pgbouncer=true) — soporta los bloqueos de esquema que necesitan
# `prisma migrate deploy`/`db:seed`/`db:studio` y es accesible por IPv4. Ver tasks/DEPLOY.md §1.2.
DATABASE_URL="postgresql://nucleo:nucleo@localhost:5432/nucleo?schema=public"
DIRECT_URL="postgresql://nucleo:nucleo@localhost:5432/nucleo?schema=public"

# ── Auth ──
JWT_SECRET="cambia-esto-por-un-secreto-largo"
JWT_REFRESH_SECRET="cambia-esto-tambien"
JWT_EXPIRES_IN="15m"
# Intentos de login/refresh permitidos por IP y minuto (opcional, default 5).
AUTH_THROTTLE_LIMIT="5"

# ── Servidor ──
PORT="3000"
# Orígenes permitidos por CORS, separados por comas (front local + producción + previews).
WEB_ORIGIN="http://localhost:5173"

# ── Almacenamiento ──
# "" (vacío) = LocalStorageProvider (disco local, dev/test). "supabase" = SupabaseStorageProvider
# real (bucket privado + URL firmada bajo demanda) — usado de verdad por la subida/descarga de
# documentos (ver apps/api/src/storage y apps/api/src/documents).
STORAGE_PROVIDER=""
SUPABASE_URL="https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="cambia-esto-por-la-service-role-key-de-supabase"
SUPABASE_STORAGE_BUCKET="nucleo-docs"

# ── Firma electrónica (proveedor; vacío = modo mock en local) ──
SIGNATURE_PROVIDER=""
SIGNATURE_API_KEY=""

# ── Frontend (Vite, solo se usa en build time del front) ──
VITE_API_URL="http://localhost:3000"
